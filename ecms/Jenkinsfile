            REMOTE_FTP_DIR = "ECMS/host/${BRANCH_NAME}/aarch64/"
        }
    
    stage 'Upload To FTP'
        dir("${WORKSPACE}/ecms/output") {
            ftpPublisher alwaysPublishFromMaster: false, 
            continueOnError: false, 
            failOnError: false, 
            publishers: [
                [configName: 'FTP_ICT', 
                    transfers: [
                        [
                            asciiMode: false, 
                            cleanRemote: false, excludes: '', 
                            flatten: false, 
                            makeEmptyDirs: false, 
                            noDefaultExcludes: false, 
                            patternSeparator: '[, ]+', 
                            remoteDirectory: "${REMOTE_FTP_DIR}", 
                            remoteDirectorySDF: false, 
                            sourceFiles: "*.rpm"
                        ]
                    ], 
                    usePromotionTimestamp: false, 
                    useWorkspaceInPromotion: false, 
                    verbose: true
                ]
            ]
        }
        ECMS_RPM_PATH = "ftp://ftp-ict.aishu.cn/proton/ECMS/host/${BRANCH_NAME}/aarch64/ecms-${ECMS_VERSION}-${BUILD_NUMBER}.el7.aarch64.rpm"
        RPM_REPO = "ftp://ftp-ict.aishu.cn/repo/centos7-aarch64.repo"
        build job: 'PROTON_YUM_REPO_UPDATE', parameters: [string(name: 'BRANCH', value: "${FTP_BRANCH_TYPE}"), string(name: 'ARCH', value: 'aarch64'), string(name: 'URL_RPM', value: "${ECMS_RPM_PATH}"), string(name: 'URL_REPO', value: "${RPM_REPO}")], propagate: false, wait: false

}