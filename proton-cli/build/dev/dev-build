#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

PROTON_ROOT=$(realpath $(dirname "${BASH_SOURCE[0]}")/../..)

rm -f "${PROTON_ROOT}/bin/proton-cli"
cd ${PROTON_ROOT}
DOCKER_BUILDKIT=1 docker build --target bin --output "type=local,dest=./bin/" ${PROTON_ROOT} -f ${PROTON_ROOT}/build/dev/Dockerfile 

echo $PROTON_ROOT