zookeeper:
  replica_count: 1
  hosts:
    - node1
    - node2
    - node3
  data_path: /sysvol/zookeeper/zookeeper_data
  # 根据 AnyRobot 性能测试的推荐资源配额
  # arch: arm, node:   1, cpu:  96, memory: 128
  env:
    JVMFLAGS: -Xms400m -Xmx400m
  resources:
    limits:
      cpu: 200m
      memory: 800Mi
    requests:
      cpu: 200m
      memory: 800Mi
  # arch: arm, node:   6, cpu:  96, memory: 128
