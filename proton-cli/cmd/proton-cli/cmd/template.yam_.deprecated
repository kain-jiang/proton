  #     cpu: "4"
  #     memory: 13Gi
  # arch: arm, node:   1, cpu:  48, memory: 128
  # env:
  #   KAFKA_HEAP_OPTS: -Xms6G -Xmx6G
  # resources:
  #   limits:
  #     cpu: "2"
  #     memory: 7Gi
  #   requests:
  #     cpu: "2"
  #     memory: 7Gi
  # arch: x86, node:   1, cpu:  32, memory:  64
  # env:
  #   KAFKA_HEAP_OPTS: -Xms4G -Xmx4G
  # resources:
  #   limits:
  #     cpu: "1"
  #     memory: 5Gi
