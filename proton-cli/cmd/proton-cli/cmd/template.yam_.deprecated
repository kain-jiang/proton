  #   username: ""
  #   password: ""
#  #internal mongodb
  mongodb:
    source_type: internal
    username: FAKE_USERNAME
    password: FAKE_PASSWORD #
# #external mongodb
  # mongodb:
  #   source_type: external
  #   hosts: ""  # 外置组件地址，多个英文逗号分隔
