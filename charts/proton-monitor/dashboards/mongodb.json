      "targets": [
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod,node,pod_ip)",
          "format": "table",
          "instant": true,
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "time() - sum(kube_pod_created{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod)",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "运行时长",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod)",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "重启次数",
          "refId": "C"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(kube_pod_container_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod)",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "容器数",
          "refId": "D"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "(sum(kube_pod_status_phase{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod,phase))>0",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "状态",
          "refId": "E"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "(sum(kube_pod_status_ready{namespace=~\"$namespace\",condition=\"true\",pod=~\"$podname\"})by(pod))",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "副本状态",
          "refId": "F"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(kube_pod_container_resource_requests{namespace=~\"$namespace\",pod=~\"$podname\", resource=\"memory\"}) by(pod) or (sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod) - sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod))",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "请求内存",
          "refId": "G"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(kube_pod_container_resource_limits{namespace=~\"$namespace\",pod=~\"$podname\", resource=\"memory\"}) by(pod) or (sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod) - sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod))",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "限制内存",
          "refId": "H"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum (container_memory_working_set_bytes{namespace=~\"$namespace\",image!=\"\", pod=~\"$podname\",container!=\"POD\"})by(pod) or (sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod) - sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod))",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "使用内存",
          "refId": "I"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(kube_pod_container_resource_requests{namespace=~\"$namespace\",pod=~\"$podname\", resource=\"cpu\"}) by(pod) or (sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod) - sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod))",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "请求CPU",
          "refId": "J"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(kube_pod_container_resource_limits{namespace=~\"$namespace\",pod=~\"$podname\", resource=\"cpu\"}) by(pod) or (sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod) - sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod))",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "限制CPU",
          "refId": "K"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum ( rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\",image!=\"\",pod=~\"$podname\"}[5m])) by(pod) or (sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod) - sum(kube_pod_info{namespace=~\"$namespace\",pod=~\"$podname\"})by(pod))",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "限制CPU",
          "refId": "L"
        },
        {
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\",pod=~\"$podname\"}[$__range]))by(pod)",
          "format": "table",
          "hide": false,
          "instant": true,
          "interval": "",
          "legendFormat": "重启次数(当前字段)",
          "refId": "M"
        }
