#!/bin/bash
set -e
workDir=$(dirname $(dirname $(dirname $(readlink -f $0))))

build_link() {
  sourceDir=$1
  dstDir=$2

  cd $dstDir

  for i in `ls $sourceDir`
  do 
    if [ "${i}" == "init_test.go" ]
    then 
      continue
    fi
    # rm -f ${dstDir}/${i}
    if [ ! -e ${dstDir}/${i} ]
    then
      ln -s ${sourceDir}/${i} ${dstDir}/${i}
    fi 
  done 
}


build_link driver/mysql/store_test ${workDir}/pkg/store/mysql

build_link store_test ${workDir}/pkg/store/mysql/driver/mysql



